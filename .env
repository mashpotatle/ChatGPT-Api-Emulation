# ─────────────────────────────────────────────────────────────
#  .env.example — copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Your Discord bot token (from Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=your_discord_bot_token_here

# Your bot's Application/Client ID (Developer Portal → General Information)
CLIENT_ID=your_client_id_here

# (Optional) Channel ID the bot is restricted to responding in
# Leave blank to allow @mentions in any channel
# Can also be set via the /setchannel slash command
ALLOWED_CHANNEL_ID=
